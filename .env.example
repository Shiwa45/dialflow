# ─── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_NAME=dialflow_db
DB_USER=dialflow_user
DB_PASSWORD=dialflow_pass
DB_HOST=localhost
DB_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Asterisk ARI ────────────────────────────────────────────────────────────
ARI_HOST=127.0.0.1
ARI_PORT=8088
ARI_USERNAME=asterisk
ARI_PASSWORD=asterisk_ari_password
ARI_APP_NAME=dialflow

# ─── Asterisk AMI ────────────────────────────────────────────────────────────
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=admin
AMI_PASSWORD=asterisk_ami_password

# ─── WebRTC / SIP ────────────────────────────────────────────────────────────
# Asterisk WebSocket for JsSIP (wss for production, ws for dev)
WEBRTC_WS_URL=ws://127.0.0.1:8088/ws
WEBRTC_DOMAIN=127.0.0.1
WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302
WEBRTC_DISABLE_STUN=True

# ─── Call Recordings ─────────────────────────────────────────────────────────
RECORDING_PATH=/var/spool/asterisk/monitor
RECORDING_URL_PREFIX=/recordings/

# ─── Email (optional) ────────────────────────────────────────────────────────
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=dialflow@localhost

# ─── System ──────────────────────────────────────────────────────────────────
TIME_ZONE=Asia/Kolkata

# Sarvam AI (for Hindi AI calling)
SARVAM_AI_API_KEY=
RECORDING_PATH=/var/spool/asterisk/monitor
